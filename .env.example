# Required: Admin API key (sk-ant-admin01-...), created by an org admin in the
# Claude Console. This is NOT a regular API key.
ANTHROPIC_ADMIN_KEY=sk-ant-admin01-REPLACE_ME

# Optional overrides (defaults shown)
EXPORTER_PORT=9402
POLL_INTERVAL_SECONDS=300
LOOKBACK_DAYS=2
PRICING_FILE=/app/pricing.json
COST_IN_CENTS=true
LOG_LEVEL=INFO
# ANTHROPIC_API_BASE=https://api.anthropic.com
# ANTHROPIC_API_VERSION=2023-06-01
